{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-push",
      "schedule": "30 14 * * *"
    },
    {
      "path": "/api/cron/weekly-report",
      "schedule": "0 13 * * 0"
    }
  ]
}
